{
  "manifest_version": 2,
  "name": "LocalCode Browser Bridge",
  "version": "1.2",
  "description": "Provides browser state and JS execution for localcode (Firefox)",
  "permissions": [
    "activeTab",
    "tabs",
    "<all_urls>"
  ],
  "content_security_policy": "script-src 'self' 'unsafe-eval'; object-src 'self'",
  "background": {
    "scripts": ["background.js"],
    "persistent": false
  },
  "browser_action": {
    "default_popup": "popup.html"
  },
  "icons": {
    "48": "icon48.png"
  }
}
